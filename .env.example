APP_NAME=LeadFlow
ENVIRONMENT=production

FRONTEND_PORT=3000
BACKEND_PORT=8000
MONGO_PORT=27017

MONGO_ROOT_USERNAME=leadflow
MONGO_ROOT_PASSWORD=change_this_password
MONGO_DB_NAME=leadflow

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Leave empty to let the Docker frontend call the backend through Nginx at /api.
# Set this at build time for a separately hosted backend, for example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
